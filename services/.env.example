# OttoChain Services Environment Variables
# Copy this to .env and fill in your values

# ============ Database ============
DATABASE_URL=postgresql://ottochain:YOUR_PASSWORD@localhost:5432/ottochain_identity

# For Docker Compose mode only:
POSTGRES_USER=ottochain
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=ottochain

# ============ Tessellation Endpoints ============
# For multi-node deployments, use plural URLs (comma-separated) for failover:
GL0_URLS=http://node1:9000,http://node2:9000,http://node3:9000
ML0_URLS=http://node1:9200,http://node2:9200,http://node3:9200
DL1_URLS=http://node1:9400,http://node2:9400,http://node3:9400

# Singular URLs (legacy fallback, single-node deployments)
GL0_URL=http://YOUR_METAGRAPH_IP:9000
GL1_URL=http://YOUR_METAGRAPH_IP:9100
ML0_URL=http://YOUR_METAGRAPH_IP:9200
CL1_URL=http://YOUR_METAGRAPH_IP:9300
DL1_URL=http://YOUR_METAGRAPH_IP:9400

# Legacy aliases (used by some services)
METAGRAPH_ML0_URL=http://YOUR_METAGRAPH_IP:9200
METAGRAPH_DL1_URL=http://YOUR_METAGRAPH_IP:9400

# ============ Webhook Configuration ============
# URL where ML0 pushes snapshot/rejection notifications to indexer
# Must be reachable from ML0 host (metagraph nodes use host network mode)
INDEXER_CALLBACK_URL=http://YOUR_SERVICES_IP:3031/webhook/snapshot

# ============ Monitoring Alerts (Optional) ============
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============ Grafana (packages/monitoring) ============
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ============ Version/Debug Info ============
# These are typically set by CI during builds, but can be overridden
# GIT_SHA=abc1234
# BUILD_TIME=2026-02-09T12:00:00Z
# VERSION=0.1.0
DEBUG=false
